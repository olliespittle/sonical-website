---
import { getCollection } from 'astro:content';

const press = (await getCollection('press')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// dates are authored as plain YYYY-MM-DD (parsed as UTC midnight); render in
// UTC so they don't shift back a day in negative-offset timezones.
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });

// Each strip previews this many cards, then "Show more" reveals the rest
// (already in the HTML, just hidden — SEO-safe). Once a strip outgrows the
// landing page, graduate its button to a "View all ->" archive page.
const PREVIEW = 3;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Newsroom — Sonical</title>
  <meta name="description" content="News and press coverage from across the Headphone 3.0 ecosystem, the appable hearing computer built on Sonical's CosmOS." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href="https://www.sonical.ai/newsroom/" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.sonical.ai/newsroom/" />
  <meta property="og:title" content="Newsroom — Sonical" />
  <meta property="og:description" content="News and press coverage from across the Headphone 3.0 ecosystem, built on Sonical's CosmOS." />
  <meta property="og:image" content="https://www.sonical.ai/sonical-share.png" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

  <style is:global>
    :root{
      --bg-0:#0c0708;
      --ink:#fbf3ea;
      --muted:#d3c2b4;
      --faint:#9c8878;
      --text-acc:#ff9e00;
      --graph-acc:#c084fc;
      --graph-line:rgba(192,132,252,.3);
      --graph-soft:rgba(192,132,252,.1);
      --glass:rgba(31,18,12,.79);
      --card:rgba(31,18,12,.62);
      --font-display:'Space Grotesk',system-ui,sans-serif;
      --font-body:'Inter',system-ui,sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{
      background:var(--bg-0);color:var(--ink);
      font-family:var(--font-body);font-size:16px;line-height:1.6;
      -webkit-font-smoothing:antialiased;overflow-x:hidden;min-height:100vh;
    }
    ::selection{background:rgba(192,132,252,.35)}
    a{color:inherit}

    /* static nebula backdrop — matches the homepage, no animation */
    .nebula{
      position:fixed;inset:0;z-index:0;pointer-events:none;
      background:
        radial-gradient(60% 50% at 78% -8%, rgba(124,45,18,.55), transparent 62%),
        radial-gradient(46% 40% at 10% 64%, rgba(255,158,0,.14), transparent 60%),
        radial-gradient(72% 60% at 50% 112%, rgba(107,33,168,.5), transparent 65%);
    }

    /* ===== Header ===== */
    header{
      position:fixed;top:0;left:0;right:0;z-index:50;
      backdrop-filter:none;background:rgba(12,7,8,.86);
      border-bottom:1px solid rgba(192,132,252,.12);
    }
    .nav-inner{
      max-width:1320px;margin:0 auto;padding:12px 26px;
      display:flex;align-items:center;justify-content:space-between;gap:18px;
    }
    .logo{display:inline-flex;color:var(--ink);text-decoration:none}
    .logo img{height:30px;width:auto;display:block}
    .nav-links{display:flex;align-items:center;gap:6px;list-style:none}
    .nav-links a{
      cursor:pointer;white-space:nowrap;text-decoration:none;
      color:var(--muted);font-family:var(--font-display);font-size:13.5px;font-weight:500;
      padding:8px 15px;border-radius:999px;border:1px solid transparent;
      transition:color .2s,border-color .2s,background .2s;
    }
    .nav-links a:hover{color:var(--ink)}
    .nav-links a.active{color:var(--text-acc);border-color:var(--graph-line);background:var(--graph-soft)}

    /* hamburger — hidden on desktop */
    .nav-toggle{
      display:none;background:none;border:1px solid var(--graph-line);
      border-radius:10px;width:42px;height:38px;cursor:pointer;padding:0;
      flex-direction:column;align-items:center;justify-content:center;gap:4px;
    }
    .nav-toggle span{display:block;width:18px;height:2px;background:var(--ink);border-radius:2px;transition:transform .2s,opacity .2s}
    header.nav-open .nav-toggle span:nth-child(1){transform:translateY(6px) rotate(45deg)}
    header.nav-open .nav-toggle span:nth-child(2){opacity:0}
    header.nav-open .nav-toggle span:nth-child(3){transform:translateY(-6px) rotate(-45deg)}
    /* tablet: keep inline but tighter */
    @media(min-width:601px) and (max-width:820px){
      .nav-inner{padding:12px 18px}
      .nav-links a{font-size:12.5px;padding:7px 11px}
    }
    /* phone: collapse into the hamburger dropdown */
    @media(max-width:600px){
      .nav-inner{position:relative;padding:10px 16px}
      .nav-toggle{display:flex}
      .nav-links{
        position:absolute;top:calc(100% + 10px);right:0;min-width:210px;
        flex-direction:column;align-items:stretch;gap:4px;display:none;
        background:rgba(20,12,10,.98);border:1px solid var(--graph-line);
        border-radius:14px;padding:8px;box-shadow:0 14px 34px rgba(0,0,0,.5);
      }
      header.nav-open .nav-links{display:flex}
      .nav-links a{font-size:14px;padding:11px 14px}
    }

    /* ===== Layout ===== */
    main{position:relative;z-index:1;max-width:1320px;margin:0 auto;padding:0 26px}
    .wrap{padding-top:130px}
    @media(max-width:760px){.wrap{padding-top:104px}}

    .eyebrow{
      display:inline-block;font-family:var(--font-display);font-size:12px;font-weight:600;
      letter-spacing:.18em;text-transform:uppercase;color:var(--graph-acc);
      padding-left:36px;position:relative;margin-bottom:16px;
    }
    .eyebrow::before{
      content:"";position:absolute;left:0;top:50%;width:28px;height:1px;
      background:var(--graph-acc);
    }
    h1{
      font-family:var(--font-display);font-weight:700;letter-spacing:-.02em;line-height:1.06;
      font-size:clamp(34px,5vw,56px);
    }
    .lede{color:var(--muted);font-size:clamp(16px,1.6vw,19px);max-width:60ch;margin-top:18px}

    .strip{margin-top:64px}
    .strip-head{
      display:flex;align-items:baseline;justify-content:space-between;gap:16px;
      padding-bottom:18px;border-bottom:1px solid rgba(192,132,252,.14);margin-bottom:30px;
    }
    .strip-head h2{font-family:var(--font-display);font-weight:600;font-size:clamp(22px,2.6vw,30px);color:var(--text-acc)}
    .strip-head .count{font-family:var(--font-display);font-size:13px;color:var(--faint);letter-spacing:.04em}

    /* ===== Press grid (frost OFF — solid cards) ===== */
    .grid{
      display:grid;gap:22px;
      grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
    }
    .card{
      display:flex;flex-direction:column;text-decoration:none;
      background:var(--card);border:1px solid rgba(192,132,252,.16);
      border-radius:16px;overflow:hidden;
      transition:border-color .2s,transform .2s;
    }
    .card:hover{border-color:var(--graph-acc);transform:translateY(-3px)}
    .card:focus-visible{outline:2px solid var(--graph-acc);outline-offset:2px}
    .thumb{aspect-ratio:16/9;background:#160d0a;overflow:hidden}
    .thumb img{width:100%;height:100%;object-fit:cover;display:block}
    .card-body{padding:18px 18px 20px;display:flex;flex-direction:column;flex:1}
    .meta{display:flex;align-items:center;gap:10px;margin-bottom:10px}
    .tag{
      font-family:var(--font-display);font-size:10.5px;font-weight:600;letter-spacing:.1em;
      text-transform:uppercase;color:var(--graph-acc);
      border:1px solid var(--graph-line);border-radius:999px;padding:3px 9px;
    }
    .date{font-family:var(--font-display);font-size:12px;color:var(--faint);letter-spacing:.03em}
    .card h3{font-family:var(--font-display);font-weight:600;font-size:16.5px;line-height:1.32;color:var(--ink)}
    .src{
      margin-top:auto;padding-top:16px;
      font-family:var(--font-display);font-size:12.5px;color:var(--muted);
      display:flex;align-items:center;justify-content:space-between;gap:10px;
    }
    .card:hover .read{color:var(--text-acc)}
    .read{color:var(--faint);transition:color .2s;white-space:nowrap}
    .outlet{color:var(--faint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

    /* preview N cards, reveal the rest on "Show more" (cards stay in the HTML) */
    .grid .card.is-hidden{display:none}
    .strip.expanded .grid .card.is-hidden{display:flex}
    .show-more{
      display:block;margin:30px auto 0;width:max-content;cursor:pointer;
      font-family:var(--font-display);font-size:14px;font-weight:600;letter-spacing:.02em;
      color:var(--ink);background:none;border:1px solid var(--graph-line);
      border-radius:999px;padding:11px 26px;
      transition:border-color .2s,color .2s,background .2s;
    }
    .show-more:hover{border-color:var(--graph-acc);color:var(--text-acc);background:var(--graph-soft)}
    .strip.expanded .show-more{display:none}

    /* ===== Footer ===== */
    footer{
      position:relative;z-index:1;max-width:1320px;margin:96px auto 0;padding:40px 26px 56px;
      border-top:1px solid rgba(192,132,252,.12);color:var(--faint);font-size:13px;
    }
    .footer-logo{display:inline-block;margin-bottom:18px}
    .footer-logo img{height:26px;width:auto;opacity:.9}
    .frow{display:flex;flex-wrap:wrap;gap:6px 26px;margin-bottom:14px;font-family:var(--font-display);font-size:13px;color:var(--muted)}
    .frow a{color:var(--text-acc);text-decoration:none}
    .frow a:hover{text-decoration:underline}
  </style>
</head>
<body>
  <div class="nebula" aria-hidden="true"></div>

  <header>
    <div class="nav-inner">
      <a class="logo" href="/" aria-label="Sonical home">
        <img src="/sonical-lockup.svg" alt="Sonical" width="161" height="30" />
      </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="/">Home</a></li>
        <li><a href="/coming-soon.html">About us</a></li>
        <li><a href="/newsroom/" class="active" aria-current="page">Newsroom</a></li>
        <li><a href="/#contact">Talk to us</a></li>
      </ul>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="navLinks">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main>
    <div class="wrap">
      <span class="eyebrow">Newsroom</span>
      <h1>Sonical in the news</h1>
      <p class="lede">
        News and press coverage from across the Headphone&nbsp;3.0 ecosystem,
        the appable hearing computer.
      </p>

      {posts.length > 0 && (
        <section class="strip" aria-labelledby="from-sonical">
          <div class="strip-head">
            <h2 id="from-sonical">From Sonical</h2>
          </div>
          <div class="grid">
            {posts.map((p, i) => (
              <a class={`card${i >= PREVIEW ? ' is-hidden' : ''}`} href={`/newsroom/${p.id}/`}>
                {p.data.image && (
                  <div class="thumb"><img src={p.data.image} alt={p.data.title} loading="lazy" /></div>
                )}
                <div class="card-body">
                  <div class="meta"><span class="date">{fmtDate(p.data.date)}</span></div>
                  <h3>{p.data.title}</h3>
                  {p.data.excerpt && <p class="src">{p.data.excerpt}</p>}
                </div>
              </a>
            ))}
          </div>
          {posts.length > PREVIEW && <button class="show-more" type="button">Show more</button>}
        </section>
      )}

      <section class="strip" aria-labelledby="in-the-press">
        <div class="strip-head">
          <h2 id="in-the-press">In the press</h2>
          <span class="count">{press.length} stories</span>
        </div>
        <div class="grid">
          {press.map((item, i) => (
            <a class={`card${i >= PREVIEW ? ' is-hidden' : ''}`} href={item.data.url} target="_blank" rel="noopener noreferrer">
              <div class="thumb">
                <img src={item.data.image} alt={item.data.title} loading="lazy" />
              </div>
              <div class="card-body">
                <div class="meta">
                  <span class="tag">{item.data.category}</span>
                  <span class="date">{fmtDate(item.data.date)}</span>
                </div>
                <h3>{item.data.title}</h3>
                <div class="src">
                  <span class="outlet">{item.data.source}</span>
                  <span class="read">Read →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
        {press.length > PREVIEW && <button class="show-more" type="button">Show more</button>}
      </section>
    </div>
  </main>

  <footer>
    <a class="footer-logo" href="/" aria-label="Sonical home">
      <img src="/sonical-lockup.svg" alt="Sonical" width="140" height="26" />
    </a>
    <div class="frow">
      <span>Looking for Remora? <a href="https://remora.pro">remora.pro</a></span>
      <span>Press and media: <a href="mailto:info@sonical.ai">info@sonical.ai</a></span>
      <span><a href="https://linkedin.com/company/sonical-inc">LinkedIn</a></span>
    </div>
    © Sonical, San Mateo, California. Founded 2020.
  </footer>

  <script is:inline>
    (function () {
      var h = document.querySelector('header');
      var t = document.getElementById('navToggle');
      var l = document.getElementById('navLinks');
      if (!h || !t || !l) return;
      function close() { h.classList.remove('nav-open'); t.setAttribute('aria-expanded', 'false'); }
      t.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = h.classList.toggle('nav-open');
        t.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      l.addEventListener('click', function (e) { if (e.target.closest('a')) close(); });
      document.addEventListener('click', function (e) { if (!h.contains(e.target)) close(); });
    })();

    // "Show more" reveals the hidden cards in its own strip
    document.querySelectorAll('.show-more').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var strip = btn.closest('.strip');
        if (strip) strip.classList.add('expanded');
      });
    });
  </script>
</body>
</html>
